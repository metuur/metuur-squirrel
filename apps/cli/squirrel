def cmd_vaults(args):
    from config_loader import (
        list_vaults, add_vault, remove_vault, set_default,
        ConfigError, ValidationError, VaultNotFoundError,
        NoVaultsConfiguredError,
    )

    subcmd = args.vaults_cmd
    try:
        if subcmd == "list":
            try:
                vaults = list_vaults()
            except NoVaultsConfiguredError:
                vaults = []
            if not vaults:
                print("(no vaults configured — run 'squirrel vaults add NAME PATH')")
                return
            for v in vaults:
                marker = "  (default)" if v.default else ""
                print(f"  {v.name:<20} {v.path}{marker}")
        elif subcmd == "add":
            v = add_vault(args.name, args.path)
            print(f"✅  Added vault {v.name!r} at {v.path}")
        elif subcmd == "remove":
            remove_vault(args.name)
            print(f"✅  Removed vault {args.name!r}")
        elif subcmd == "default":
            set_default(args.name)
            print(f"✅  Default vault is now {args.name!r}")
        else:
            print(f"❌  Unknown vaults subcommand: {subcmd}", file=sys.stderr)
            sys.exit(1)
    except (ValidationError, VaultNotFoundError, NoVaultsConfiguredError) as e:
        print(f"❌  {e}", file=sys.stderr)
        sys.exit(1)
    except ConfigError as e:
        print(f"❌  Config error: {e}", file=sys.stderr)
        sys.exit(1)


