_WEB_PID_PATH = Path("~/.squirrel/web-ui.pid").expanduser()
_WEB_LAUNCHD_PLIST = Path(
    "~/Library/LaunchAgents/org.squirrel.web-ui.plist"
).expanduser()


def _web_server_script() -> Path:
    """Locate companions/web-ui/server.py — repo or installed plugin path."""
    here = Path(__file__).resolve().parent / "companions" / "web-ui" / "server.py"
    if here.is_file():
        return here
    for cand in [
        Path("~/.claude/plugins/squirrel/companions/web-ui/server.py").expanduser(),
        Path("~/.codex/plugins/squirrel/companions/web-ui/server.py").expanduser(),
    ]:
        if cand.is_file():
            return cand
    raise FileNotFoundError("companions/web-ui/server.py not found")


def _web_running_pid() -> int:
    """Return the PID from the pid file if the process is alive, else 0."""
    if not _WEB_PID_PATH.is_file():
        return 0
    try:
        pid = int(_WEB_PID_PATH.read_text().strip() or "0")
    except (OSError, ValueError):
        return 0
    if pid <= 0:
        return 0
    try:
        import os as _os
        _os.kill(pid, 0)  # signal 0: probe only
    except (OSError, ProcessLookupError):
        return 0
    return pid


def cmd_web(args):
    sub = args.web_cmd
    if sub == "start":
        _web_start(args.port, args.lan)
    elif sub == "stop":
        _web_stop()
    elif sub == "status":
        _web_status()
    elif sub == "open":
        _web_open(args.port)
    elif sub == "uninstall":
        _web_uninstall()
    else:
        print(f"❌  Unknown web subcommand: {sub}", file=sys.stderr)
        sys.exit(1)


def _web_start(port: int, lan: bool) -> None:
    import subprocess
    existing = _web_running_pid()
    if existing:
        url = f"http://127.0.0.1:{port}"
        print(f"ℹ️   Already running on {url} (pid {existing})")
        return
    try:
        server = _web_server_script()
    except FileNotFoundError as e:
        print(f"❌  {e}", file=sys.stderr)
        sys.exit(1)
    cmd = [sys.executable, str(server), "--port", str(port)]
    if lan:
        cmd.append("--lan")
    _WEB_PID_PATH.parent.mkdir(parents=True, exist_ok=True)
    # Detach so the parent shell exits independently.
    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    _WEB_PID_PATH.write_text(str(proc.pid))
    host = "127.0.0.1" if not lan else "0.0.0.0"
    print(f"✅  Web UI started on http://{host}:{port}  (pid {proc.pid})")


def _web_stop() -> None:
    import os as _os
    import signal
    import time
    pid = _web_running_pid()
    if not pid:
        if _WEB_PID_PATH.is_file():
            _WEB_PID_PATH.unlink()
        print("ℹ️   Web UI was not running.")
        return
    try:
        _os.kill(pid, signal.SIGTERM)
    except OSError as e:
        print(f"❌  Could not stop pid {pid}: {e}", file=sys.stderr)
    for _ in range(50):  # up to ~5 s
        time.sleep(0.1)
        try:
            _os.kill(pid, 0)
        except OSError:
            break
    else:
        try:
            _os.kill(pid, signal.SIGKILL)
        except OSError:
            pass
    if _WEB_PID_PATH.is_file():
        _WEB_PID_PATH.unlink()
    print("✅  Web UI stopped.")


def _web_status() -> None:
    pid = _web_running_pid()
    if pid:
        print(f"running on http://127.0.0.1:3939 (pid {pid})")
        sys.exit(0)
    print("not running")
    sys.exit(1)


def _web_open(port: int) -> None:
    if not _web_running_pid():
        _web_start(port, False)
    import webbrowser
    webbrowser.open(f"http://127.0.0.1:{port}")


def _web_uninstall() -> None:
    _web_stop()
    if _WEB_LAUNCHD_PLIST.is_file():
        try:
            import subprocess
            subprocess.run(
                ["launchctl", "unload", str(_WEB_LAUNCHD_PLIST)],
                capture_output=True,
            )
        except FileNotFoundError:
            pass
        _WEB_LAUNCHD_PLIST.unlink()
        print(f"✅  Removed launchd plist: {_WEB_LAUNCHD_PLIST}")
    if _WEB_PID_PATH.is_file():
        _WEB_PID_PATH.unlink()
    print("✅  Web UI uninstalled.")


