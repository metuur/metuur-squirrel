        epilog="Run 'cb <command> --help' for per-command options.",
    )
    p.add_argument("--json", action="store_true", help="Raw JSON output")
    sub = p.add_subparsers(dest="cmd", required=True)

    st = sub.add_parser("status", help="WIP projects, alerts, recommended focus")
    st.add_argument("--vault", metavar="NAME",
                    help="Operate on the named vault (default: configured default)")

    dl = sub.add_parser("deadlines", help="Deadline report grouped by urgency")
    dl.add_argument("--level", metavar="LEVELS",
                    help="Comma-separated: overdue,critical,urgent,soon,upcoming,future_fyi")
    dl.add_argument("--vault", metavar="NAME",
                    help="Operate on the named vault (default: configured default)")

    ch = sub.add_parser("chunk", help="Decompose a task into ADHD-friendly chunks")
    grp = ch.add_mutually_exclusive_group(required=True)
    grp.add_argument("--minutes", type=int)
    grp.add_argument("--hours", type=float)

    est = sub.add_parser("estimate", help="Apply ADHD time buffer to an estimate")
    grp2 = est.add_mutually_exclusive_group(required=True)
    grp2.add_argument("--minutes", type=int)
    grp2.add_argument("--hours", type=float)
    grp2.add_argument("--estimate", metavar="STR", help="e.g. '90 min' or '2.5h'")

    rec = sub.add_parser("recover", help="Find interrupted sessions (from manifest or Claude history)")
    rec.add_argument("--max-age", type=int, default=72, dest="max_age", metavar="HOURS",
                     help="Max session age in hours (default: 72)")
    rec.add_argument("--vault", metavar="NAME",
                     help="Operate on the named vault (default: configured default)")

    dash = sub.add_parser("dashboard", help="Generate HTML dashboard and optionally open in browser")
    dash.add_argument("--out", metavar="FILE", help="Output path (default: ~/.squirrel/dashboard.html)")
    dash.add_argument("--open", action="store_true", dest="open_browser", help="Open in browser after generating")
    dash.add_argument("--vault", metavar="NAME",
                      help="Operate on the named vault (default: configured default)")

    inst = sub.add_parser("install", help="Install squirrel for your agent (Claude Code, Codex, Cursor)")
    inst.add_argument("--agent", choices=["claude", "codex", "cursor", "standalone"],
                      help="Target agent (auto-detected if omitted)")
    inst.add_argument("--link", action="store_true",
                      help="Create symlinks instead of copying (stays updatable from repo)")
    inst.add_argument("--dry-run", action="store_true", dest="dry_run",
                      help="Show what would be done without making changes")

    # vaults subcommand group
    v = sub.add_parser("vaults", help="Manage configured vaults")
    v_sub = v.add_subparsers(dest="vaults_cmd", required=True)
    v_sub.add_parser("list", help="List all configured vaults")
    v_add = v_sub.add_parser("add", help="Add a new vault")
    v_add.add_argument("name", help="Short name (e.g., personal, work, client-a)")
    v_add.add_argument("path", help="Path to the vault directory")
    v_rm = v_sub.add_parser("remove", help="Remove a vault from config (files untouched)")
    v_rm.add_argument("name", help="Name of the vault to remove")
    v_def = v_sub.add_parser("default", help="Set the default vault")
    v_def.add_argument("name", help="Name of the vault to make default")

    # web subcommand group — companions/web-ui lifecycle
    w = sub.add_parser("web", help="Manage the local browser interface")
    w_sub = w.add_subparsers(dest="web_cmd", required=True)
    w_start = w_sub.add_parser("start", help="Start the web UI server")
    w_start.add_argument("--port", type=int, default=3939, help="Port (default: 3939)")
    w_start.add_argument("--lan", action="store_true",
                         help="Bind 0.0.0.0 (LAN-reachable, no auth)")
    w_sub.add_parser("stop", help="Stop the running web UI server")
    w_sub.add_parser("status", help="Print whether the web UI is running")
    w_open = w_sub.add_parser("open", help="Open the web UI in the browser (starts if needed)")
    w_open.add_argument("--port", type=int, default=3939)
    w_sub.add_parser("uninstall", help="Stop server, remove PID file and launchd plist")

    args = p.parse_args()
    args.json = getattr(args, "json", False)

    dispatch = {
        "status": cmd_status,
        "deadlines": cmd_deadlines,
        "chunk": cmd_chunk,
        "estimate": cmd_estimate,
        "recover": cmd_recover,
        "dashboard": cmd_dashboard,
        "install": cmd_install,
        "vaults": cmd_vaults,
        "web": cmd_web,
    }
    dispatch[args.cmd](args)


if __name__ == "__main__":
    main()
