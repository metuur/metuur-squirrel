                      help="Operate on the named vault (default: configured default)")

    inst = sub.add_parser("install", help="Install squirrel for your agent (Claude Code, Codex, Cursor, Copilot)")
    inst.add_argument("--agent", choices=["claude", "codex", "cursor", "copilot", "standalone"],
                      help="Target agent (auto-detected if omitted)")
