def _read_config() -> dict:
    """Legacy helper kept for backward compatibility. New callers should use
    `from config_loader import ...` directly."""
    cfg = Path("~/.squirrel/config.toml").expanduser()
    if not cfg.exists():
        return {}
    result = {}
    for line in cfg.read_text(encoding="utf-8").splitlines():
        s = line.strip()
        if not s or s.startswith("#") or s.startswith("["):
            continue
        if "=" in s:
            k, _, v = s.partition("=")
            result[k.strip()] = v.strip().strip("\"'")
    return result


def _vault(name=None) -> Path:
    """Resolve a vault by name (or default if name is None) via config_loader."""
    from config_loader import (
        get_vault, NoVaultsConfiguredError, VaultNotFoundError, ConfigError,
    )
    try:
        return get_vault(name=name).path
    except NoVaultsConfiguredError as e:
        print(f"❌  {e}", file=sys.stderr)
        sys.exit(1)
    except VaultNotFoundError as e:
        print(f"❌  {e}", file=sys.stderr)
        sys.exit(1)
    except ConfigError as e:
        print(f"❌  {e}", file=sys.stderr)
        sys.exit(1)


