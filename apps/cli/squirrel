def cmd_estimate(args):
    from estimate_buffer import adjust_estimate, parse_estimate
    if args.minutes is not None:
        mins = float(args.minutes)
    elif args.hours is not None:
        mins = args.hours * 60
    else:
        try:
            mins = parse_estimate(args.estimate)
        except ValueError as e:
            print(f"❌  {e}", file=sys.stderr)
            sys.exit(1)

    data = adjust_estimate(mins)
    if args.json:
        print(json.dumps(data, indent=2))
        return

    print(f"⏱️  {data['user_estimate_human']}  →  {data['adjusted_human']}  (×{data['multiplier']})")
    print(f"\n   {data['explanation']}")


