_WEB_PID_PATH = Path("~/.squirrel/web-ui.pid").expanduser()
_WEB_LAUNCHD_PLIST = Path(
    "~/Library/LaunchAgents/org.squirrel.web-ui.plist"
).expanduser()
_WEB_TOKEN_PATH = Path("~/.squirrel/launchd-token").expanduser()


def _web_server_script() -> Path:
    """Locate the backend server.py — monorepo, sibling, or installed-plugin path."""
    cli_dir = Path(__file__).resolve().parent
    candidates = [
        cli_dir.parent / "backend" / "server.py",                 # monorepo: apps/backend/
        cli_dir / "companions" / "web-ui" / "server.py",          # legacy in-tree layout
        Path("~/.claude/plugins/squirrel/companions/web-ui/server.py").expanduser(),
        Path("~/.codex/plugins/squirrel/companions/web-ui/server.py").expanduser(),
    ]
    for cand in candidates:
        if cand.is_file():
            return cand
    raise FileNotFoundError("backend server.py not found (checked monorepo + plugin paths)")


def _find_backend_binary() -> "Path | None":
    """Locate the compiled squirrel-backend binary for installed (non-dev) runs."""
    import shutil
    cli_dir = Path(__file__).resolve().parent
    candidates = [
        cli_dir / "squirrel-backend",          # sibling of squirrel binary (~/.local/bin/)
        Path("~/.local/bin/squirrel-backend").expanduser(),
    ]
    for cand in candidates:
        if cand.is_file() and os.access(cand, os.X_OK):
            return cand
    # Last resort: PATH lookup
    found = shutil.which("squirrel-backend")
    return Path(found) if found else None


def _web_running_pid() -> int:
    """Return the PID from the pid file if the process is alive, else 0."""
    if not _WEB_PID_PATH.is_file():
        return 0
    try:
        pid = int(_WEB_PID_PATH.read_text().strip() or "0")
    except (OSError, ValueError):
        return 0
    if pid <= 0:
        return 0
    try:
        import os as _os
        _os.kill(pid, 0)  # signal 0: probe only
    except (OSError, ProcessLookupError):
        return 0
    return pid


def cmd_web(args):
    sub = args.web_cmd
    if sub == "start":
        _web_start(args.port, args.lan)
    elif sub == "stop":
        _web_stop()
    elif sub == "status":
        _web_status()
    elif sub == "open":
        _web_open(args.port)
    elif sub == "open-web":
        _web_open_browser(args.port)
    elif sub == "uninstall":
        _web_uninstall()
    else:
        print(f"❌  Unknown web subcommand: {sub}", file=sys.stderr)
        sys.exit(1)


def _web_start(port: int, lan: bool) -> None:
    import subprocess
    existing = _web_running_pid()
    if existing:
        url = f"http://127.0.0.1:{port}"
        print(f"ℹ️   Already running on {url} (pid {existing})")
        return
    try:
        server = _web_server_script()
        cmd = [sys.executable, str(server), "--port", str(port)]
    except FileNotFoundError:
        backend_bin = _find_backend_binary()
        if backend_bin is None:
            print(
                "❌  backend not found — install squirrel-backend or run from the monorepo",
                file=sys.stderr,
            )
            sys.exit(1)
        cmd = [str(backend_bin), "--port", str(port)]
    if lan:
        cmd.append("--lan")
    _WEB_PID_PATH.parent.mkdir(parents=True, exist_ok=True)
    # Detach so the parent shell exits independently.
    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    _WEB_PID_PATH.write_text(str(proc.pid))
    host = "127.0.0.1" if not lan else "0.0.0.0"
    print(f"✅  Web UI started on http://{host}:{port}  (pid {proc.pid})")


def _web_stop() -> None:
    import os as _os
    import signal
    import time
    pid = _web_running_pid()
    if not pid:
        if _WEB_PID_PATH.is_file():
            _WEB_PID_PATH.unlink()
        print("ℹ️   Web UI was not running.")
        return
    try:
        _os.kill(pid, signal.SIGTERM)
    except OSError as e:
        print(f"❌  Could not stop pid {pid}: {e}", file=sys.stderr)
    for _ in range(50):  # up to ~5 s
        time.sleep(0.1)
        try:
            _os.kill(pid, 0)
        except OSError:
            break
    else:
        try:
            _os.kill(pid, signal.SIGKILL)
        except OSError:
            pass
    if _WEB_PID_PATH.is_file():
        _WEB_PID_PATH.unlink()
    print("✅  Web UI stopped.")


def _web_status() -> None:
    pid = _web_running_pid()
    if pid:
        print(f"running on http://127.0.0.1:3939 (pid {pid})")
        sys.exit(0)
    print("not running")
    sys.exit(1)


def _web_open(port: int) -> None:
    # Delegate to open-web: TCP probe works for both launchd and manually started backends.
    _web_open_browser(port)


def _port_listening(port: int) -> bool:
    """Return True if something is already accepting TCP connections on localhost:port."""
    import socket
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.settimeout(0.5)
        return s.connect_ex(("127.0.0.1", port)) == 0


def _web_open_browser(port: int) -> None:
    """Open the web UI in the browser, embedding the launchd token in the URL
    so the SPA can authenticate against a token-protected backend.

    Uses a TCP probe instead of the PID file so it works whether the backend
    was started via launchd, squirrel web start, or manually."""
    if not _port_listening(port):
        _web_start(port, False)
    import webbrowser
    url = f"http://127.0.0.1:{port}"
    if _WEB_TOKEN_PATH.is_file():
        try:
            token = _WEB_TOKEN_PATH.read_text(encoding="utf-8").strip()
            if token:
                url = f"{url}/?token={token}"
        except OSError:
            pass
    webbrowser.open(url)


def _web_uninstall() -> None:
    _web_stop()
    if _WEB_LAUNCHD_PLIST.is_file():
        try:
            import subprocess
            subprocess.run(
                ["launchctl", "unload", str(_WEB_LAUNCHD_PLIST)],
                capture_output=True,
            )
        except FileNotFoundError:
            pass
        _WEB_LAUNCHD_PLIST.unlink()
        print(f"✅  Removed launchd plist: {_WEB_LAUNCHD_PLIST}")
    if _WEB_PID_PATH.is_file():
        _WEB_PID_PATH.unlink()
    print("✅  Web UI uninstalled.")


