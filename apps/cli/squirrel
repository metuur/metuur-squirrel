_URGENCY_ORDER = ["overdue", "critical", "urgent", "soon", "upcoming", "future_fyi"]
_ICONS = {
    "overdue": "💀",
    "critical": "🔴",
    "urgent": "🟠",
    "soon": "🟡",
    "upcoming": "🔵",
    "future_fyi": "🟢",
}


def cmd_deadlines(args):
    from deadline_scanner import scan_vault_deadlines
    data = scan_vault_deadlines(_vault(getattr(args, "vault", None)))
    if args.json:
        print(json.dumps(data, indent=2, default=str))
        return

    by_urgency = data.get("by_urgency", {})
    filter_lvls = set(args.level.split(",")) if args.level else set(_URGENCY_ORDER)
    shown = 0

    for lvl in _URGENCY_ORDER:
        if lvl not in filter_lvls:
            continue
        items = by_urgency.get(lvl, [])
        if not items:
            continue
        print(f"\n{_ICONS[lvl]} {lvl.upper()} ({len(items)})")
        for item in items:
            tag = item.get("id", "?")
            title = item.get("title", "")
            dl = item.get("deadline", "")
            days = item.get("days_left", item.get("days_overdue"))
            hrs = item.get("hours_left")
            if lvl == "overdue":
                time_str = f"{days}d overdue" if days else "overdue"
            elif hrs is not None and hrs < 24:
                time_str = f"{hrs}h left"
            elif days is not None:
                time_str = f"{days}d left"
            else:
                time_str = ""
            suffix = f" ({time_str})" if time_str else ""
            print(f"  {tag} — {title} — {dl}{suffix}")
            shown += 1

    if shown == 0:
        print("✅  No deadlines found.")
    else:
        total = data.get("total_intents_with_deadline", shown)
        print(f"\n  Total: {total} intent(s) with deadline")


