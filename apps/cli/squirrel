def cmd_status(args):
    from status_aggregator import aggregate_status
    data = aggregate_status(_vault(getattr(args, "vault", None)))
    if args.json:
        print(json.dumps(data, indent=2, default=str))
        return

    print(f"📊 Vault Status — {data.get('scanned_at', '')[:10]}\n")

    wip = data.get("wip", {})
    projs = wip.get("projects", [])
    print(f"🟢 WIP ({len(projs)}/{wip.get('max', 3)})")
    for i, p in enumerate(projs, 1):
        pct = p.get("intents", {}).get("percent_done", 0)
        dl = p.get("deadline", "—")
        last = p.get("active_intent", "")
        print(f"  {i}. {p['id']} — {pct}% — deadline: {dl} — last: {last}")

    parking = data.get("parking_lot", {}).get("items", [])
    if parking:
        print(f"\n🚧 PARKING ({len(parking)})")
        for p in parking:
            pid = p.get("id", str(p)) if isinstance(p, dict) else str(p)
            print(f"  • {pid}")

    alerts = data.get("alerts", [])
    if alerts:
        print(f"\n⚠️  ALERTS")
        for a in alerts:
            print(f"  • {a.get('project', '?')}: {a.get('message')} [{a.get('level')}]")

    focus = data.get("recommended_focus") or {}
    if focus:
        print(f"\n🎯 FOCUS: {focus.get('project')} — {focus.get('reason', '')}")
        na = focus.get("next_action", "")
        if na:
            print(f"   Next: {na}")


