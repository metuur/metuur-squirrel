def _parse_skill_frontmatter(body: str) -> dict:
    """Extract YAML frontmatter fields from a Markdown file (no PyYAML needed)."""
    if not body.startswith("---"):
        return {}
    end = body.find("\n---", 3)
    if end == -1:
        return {}
    fm_block = body[3:end].strip()
    result: dict = {}
    for line in fm_block.splitlines():
        if ":" in line:
            key, _, val = line.partition(":")
            result[key.strip()] = val.strip().strip('"').strip("'")
    return result


def _inject_copilot_frontmatter(body: str, source_meta: dict) -> str:
    """Prepend Copilot-compatible frontmatter if the body does not already have it.

    Returns the body unchanged if it already contains all required Copilot fields.
    """
    required = {"description", "name", "agent", "model", "tools", "argument-hint"}
    existing = _parse_skill_frontmatter(body)
    if required.issubset(existing.keys()):
        return body

    name = source_meta.get("name", "")
    description = source_meta.get("description", "")
    if not description and name:
        description = f"Squirrel {name} skill"

    header = (
        "---\n"
        f"description: \"{description}\"\n"
        f"name: \"{name}\"\n"
        "agent: copilot\n"
        "model: gpt-4o\n"
        "tools: []\n"
        "argument-hint: \"\"\n"
        "---\n"
    )
    # Remove existing Claude-style frontmatter so we don't double-stack headers.
    stripped = body
    if body.startswith("---"):
        end = body.find("\n---", 3)
        if end != -1:
            stripped = body[end + 4:].lstrip("\n")
    return header + stripped


def _copy_skill_for_copilot(
    src_skill_dir: Path, dst_agents_dir: Path, link: bool, dry: bool
) -> None:
    """Copy/link a single skill to the Copilot agents directory.

    src_skill_dir — e.g. agent-pack/skills/session-start/
    dst_agents_dir — e.g. ~/.copilot/agents/
    Renames SKILL.md → squirrel-<skill-name>.agent.md and injects frontmatter.
    """
    skill_name = src_skill_dir.name
    src_file = src_skill_dir / "SKILL.md"
    if not src_file.exists():
        return
    dst_file = dst_agents_dir / f"squirrel-{skill_name}.agent.md"

    if dry:
        print(f"  [copilot-skill] {skill_name} → {dst_file}")
        return

    dst_agents_dir.mkdir(parents=True, exist_ok=True)
    if link:
        if dst_file.is_symlink() or dst_file.is_file():
            dst_file.unlink()
        dst_file.symlink_to(src_file.resolve())
    else:
        body = src_file.read_text(encoding="utf-8")
        meta = _parse_skill_frontmatter(body)
        if not meta.get("name"):
            meta["name"] = f"squirrel-{skill_name}"
        patched = _inject_copilot_frontmatter(body, meta)
        dst_file.write_text(patched, encoding="utf-8")


def _copy_prompt_for_copilot(
    src_cmd_file: Path, dst_prompts_dir: Path, link: bool, dry: bool
) -> None:
    """Copy/link a single command file to the Copilot prompts directory.

    src_cmd_file — e.g. agent-pack/commands/sq-start.md
    dst_prompts_dir — e.g. ~/.copilot/prompts/
    Renames sq-<cmd>.md → sq-<cmd>.prompt.md and injects frontmatter.
    """
    cmd_stem = src_cmd_file.stem  # e.g. sq-start
    dst_file = dst_prompts_dir / f"{cmd_stem}.prompt.md"

    if dry:
        print(f"  [copilot-prompt] {src_cmd_file.name} → {dst_file}")
        return

    dst_prompts_dir.mkdir(parents=True, exist_ok=True)
    if link:
        if dst_file.is_symlink() or dst_file.is_file():
            dst_file.unlink()
        dst_file.symlink_to(src_cmd_file.resolve())
    else:
        body = src_cmd_file.read_text(encoding="utf-8")
        meta = _parse_skill_frontmatter(body)
        if not meta.get("name"):
            meta["name"] = cmd_stem
        if not meta.get("description"):
            meta["description"] = f"Squirrel {cmd_stem} slash command"
        patched = _inject_copilot_frontmatter(body, meta, kind="prompt")
        dst_file.write_text(patched, encoding="utf-8")


def _patch_copilot_instructions_md(dest: Path, dry: bool) -> None:
    """Ensure dest contains the Squirrel manifest block.

    Mirrors _patch_codex_agents_md() but targets copilot-instructions.md.
    Prints 'created', 'patched', or 'skipped (already present)'.
    """
    marker = "# Squirrel — Copilot Agent Manifest"
    if dest.exists():
        content = dest.read_text(encoding="utf-8")
        if marker in content:
            print(f"  skipped (already present)  {dest}")
            return
        if dry:
            print(f"  [patch] {dest}")
            return
        dest.write_text(content.rstrip() + "\n\n" + _COPILOT_INSTRUCTIONS_BLOCK, encoding="utf-8")
        print(f"  patched  {dest}")
    else:
        if dry:
            print(f"  [create] {dest}")
            return
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(_COPILOT_INSTRUCTIONS_BLOCK, encoding="utf-8")
        print(f"  created  {dest}")


def _emit_copilot_hooks_json(dest: Path, adapter_dir: Path, dry: bool) -> None:
    """Write ~/.copilot/hooks/squirrel.json (or .github/hooks/squirrel.json).

    R-6.6: If the file exists and contains non-Squirrel hooks, warn and skip.
    R-6.5: Otherwise, overwrite entirely (generated content).
    """
    import json as _json

    # Resolve hook body from hooks.json. When run from canonical install
    # (~/.claude/plugins/squirrel/) the file is at hooks/hooks.json. When run
    # from the repo (apps/cli/squirrel), fall back to agent-pack/hooks/hooks.json.
    _script_dir = Path(__file__).resolve().parent
    hooks_json_path = _script_dir / "hooks" / "hooks.json"
    if not hooks_json_path.exists():
        hooks_json_path = _script_dir.parent.parent / "agent-pack" / "hooks" / "hooks.json"
    post_tool_body = ""
    session_start_body = ""
    user_prompt_bodies: list[str] = []
    stop_body = ""
    if hooks_json_path.exists():
        try:
            hdata = _json.loads(hooks_json_path.read_text(encoding="utf-8"))
            hooks = hdata.get("hooks", {})
            ss_hooks = hooks.get("SessionStart", [{}])[0].get("hooks", [])
            if ss_hooks:
                session_start_body = ss_hooks[0].get("command", "")
            up_hooks = hooks.get("UserPromptSubmit", [{}])[0].get("hooks", [])
            user_prompt_bodies = [h.get("command", "") for h in up_hooks if h.get("command")]
            stop_hooks = hooks.get("Stop", [{}])[0].get("hooks", [])
            if stop_hooks:
                stop_body = stop_hooks[0].get("command", "")
            pt_hooks = hooks.get("PostToolUse", [{}])[0].get("hooks", [])
            if pt_hooks:
                post_tool_body = pt_hooks[0].get("command", "")
        except Exception:
            pass

    adapter = str(adapter_dir / "hook-adapter.sh")

    def _cmd(event: str, body: str) -> str:
        escaped = body.replace("'", "'\\''")
        return f"bash '{adapter}' {event} '{escaped}'"

    entries = []

    if session_start_body:
        entries.append({
            "event": "sessionStart",
            "squirrel_event": "SessionStart",
            "command": _cmd("SessionStart", session_start_body),
        })

    for body in user_prompt_bodies:
        entries.append({
            "event": "userPromptSubmitted",
            "squirrel_event": "UserPromptSubmit",
            "command": _cmd("UserPromptSubmit", body),
        })

    if stop_body:
        entries.append({
            "event": "sessionEnd",
            "squirrel_event": "Stop",
            "command": _cmd("Stop", stop_body),
        })

    if post_tool_body:
        entries.append({
            "event": "postToolUse",
            "squirrel_event": "PostToolUse",
            "command": _cmd("PostToolUse", post_tool_body),
        })

    payload = _json.dumps(entries, indent=2, ensure_ascii=False)

    if dry:
        print(f"  [hooks-json] {dest}  ({len(entries)} entries)")
        return

    # R-6.6: detect non-Squirrel entries in an existing file.
    if dest.exists():
        try:
            existing = _json.loads(dest.read_text(encoding="utf-8"))
            if isinstance(existing, list):
                for item in existing:
                    cmd = item.get("command", "")
                    if cmd and "hook-adapter.sh" not in cmd and "squirrel" not in cmd.lower():
                        print(
                            f"  ⚠️  {dest} contains non-Squirrel hooks — skipping overwrite.\n"
                            "     Move those entries to a separate file, then re-run."
                        )
                        return
        except Exception:
            pass

    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_text(payload + "\n", encoding="utf-8")
    print(f"  ✅  hooks → {dest}  ({len(entries)} entries)")


def _copy_or_link(src: Path, dst: Path, link: bool, dry: bool) -> None:
    import shutil
    action = "symlink" if link else "copy"
    if dry:
        print(f"  [{action}] {src.name} → {dst}")
        return
    dst.parent.mkdir(parents=True, exist_ok=True)
    if link:
        if dst.is_symlink() or dst.is_file():
            dst.unlink()
        elif dst.is_dir():
            shutil.rmtree(dst)
        dst.symlink_to(src.resolve())
    elif src.is_dir():
        if dst.exists():
            shutil.rmtree(dst)
        shutil.copytree(src, dst)
    else:
        shutil.copy2(src, dst)


def _register_claude_marketplace(plugin_root: Path, dry: bool) -> None:
    """Make Claude Code actually load the plugin.

    Just copying files into ~/.claude/plugins/squirrel/ is NOT enough — Claude
    Code needs THREE registrations:

      1. ~/.claude/plugins/known_marketplaces.json  — registers the marketplace.
      2. ~/.claude/plugins/installed_plugins.json   — records the install.
      3. ~/.claude/settings.json                    — extraKnownMarketplaces
                                                       + enabledPlugins.

    We use the directory-as-marketplace pattern: the repo IS the marketplace
    named "squirrel" and contains a single plugin also named "squirrel".
    Both manifests live side-by-side at the marketplace root:

      .claude-plugin/marketplace.json — lists the plugin(s) in this marketplace
      .claude-plugin/plugin.json      — describes the plugin itself

    No symlink dance. No nested marketplaces/ dir. The earlier "drop
    marketplace.json" fix (62e5aea) was for an obsolete install path that
    symlinked the repo INTO a separate marketplace dir, causing the loader
    to treat the symlinked source as a nested marketplace. Under the current
    pattern, marketplace.json at the repo root is required — without it,
    `claude doctor` reports "Plugin squirrel not found in marketplace squirrel".

    Idempotent. After this runs, the user needs to RESTART Claude Code.
    """
    import datetime as _dt
    import json as _json

    repo = str(plugin_root.resolve())
    now = _dt.datetime.now(_dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.000Z")

    km_path = Path("~/.claude/plugins/known_marketplaces.json").expanduser()
    ip_path = Path("~/.claude/plugins/installed_plugins.json").expanduser()
    st_path = Path("~/.claude/settings.json").expanduser()

    if dry:
        print(f"  [registry] add 'squirrel' marketplace → {repo}")
        print(f"  [registry] install 'squirrel@squirrel' in {ip_path.name}")
        print(f"  [registry] enable 'squirrel@squirrel' in settings.json")
        return

    def _load(p: Path, default: dict) -> dict:
        if not p.is_file():
            return dict(default)
        try:
            return _json.loads(p.read_text())
        except _json.JSONDecodeError:
            print(f"  ⚠️   {p} is malformed; not modifying.")
            return dict(default)

    # 1. known_marketplaces.json
    km = _load(km_path, {})
    # Wipe any legacy "squirrel-local" leftover
    km.pop("squirrel-local", None)
    km["squirrel"] = {
        "source": {"source": "directory", "path": repo},
        "installLocation": repo,
        "lastUpdated": now,
    }
    km_path.parent.mkdir(parents=True, exist_ok=True)
    km_path.write_text(_json.dumps(km, indent=2))

    # 2. installed_plugins.json
    ip = _load(ip_path, {"version": 2, "plugins": {}})
    ip.setdefault("plugins", {})
    ip["plugins"].pop("squirrel@squirrel-local", None)
    ip["plugins"]["squirrel@squirrel"] = [{
        "scope": "user",
        "installPath": repo,
        "version": "0.7.21",
        "installedAt": now,
        "lastUpdated": now,
        "gitCommitSha": "",
    }]
    ip_path.write_text(_json.dumps(ip, indent=2))

    # 3. settings.json — extraKnownMarketplaces + enabledPlugins
    st = _load(st_path, {})
    ekm = st.setdefault("extraKnownMarketplaces", {})
    ekm.pop("squirrel-local", None)
    ekm["squirrel"] = {"source": {"source": "directory", "path": repo}}

    ep = st.setdefault("enabledPlugins", {})
    ep.pop("squirrel@squirrel-local", None)  # clean up legacy
    already_enabled = ep.get("squirrel@squirrel") is True
    ep["squirrel@squirrel"] = True
    st_path.write_text(_json.dumps(st, indent=4))

    if already_enabled:
        print(f"  ✅  Marketplace + enable already set; restart Claude Code if commands are missing.")
    else:
        print(f"  ✅  Registered marketplace 'squirrel' → {repo}")
        print(f"  ✅  Enabled 'squirrel@squirrel' in settings.json")
        print(f"  ℹ️   Restart Claude Code to load the slash commands.")


def _patch_codex_agents_md(dry: bool) -> None:
    agents_md = Path("~/.codex/AGENTS.md").expanduser()
    marker = "# Context Bridge"
    if agents_md.exists():
        content = agents_md.read_text(encoding="utf-8")
        if marker in content:
            print(f"  ✅  AGENTS.md already contains squirrel — skipping")
            return
        if dry:
            print(f"  [patch] {agents_md}")
            return
        agents_md.write_text(content.rstrip() + "\n\n" + _CODEX_AGENTS_BLOCK, encoding="utf-8")
    else:
        if dry:
            print(f"  [create] {agents_md}")
            return
        agents_md.parent.mkdir(parents=True, exist_ok=True)
        agents_md.write_text(_CODEX_AGENTS_BLOCK, encoding="utf-8")
    print(f"  ✅  AGENTS.md → {agents_md}")


def cmd_install(args):
    plugin_root = Path(__file__).resolve().parent
    dry = args.dry_run
    link = args.link

    agent = args.agent
    if not agent:
        if Path("~/.claude").expanduser().exists():
            agent = "claude"
        elif Path("~/.codex").expanduser().exists():
            agent = "codex"
        elif Path("~/.cursor").expanduser().exists():
            agent = "cursor"
        elif Path("~/.copilot").expanduser().exists():
            agent = "copilot"
        else:
            agent = "standalone"

    print(f"🔧  Installing squirrel for {agent}{'  [dry run]' if dry else ''}\n")

    if agent == "claude":
        dst = Path("~/.claude/plugins/squirrel").expanduser()
        _copy_or_link(plugin_root, dst, link, dry)
        print(f"  ✅  Plugin → {dst}")
        _register_claude_marketplace(plugin_root, dry)

    elif agent == "codex":
        skills_dst = Path("~/.codex/skills").expanduser()
        cmds_dst = Path("~/.codex/commands").expanduser()
        for skill_dir in sorted((plugin_root / "skills").iterdir()):
            if skill_dir.is_dir() and not skill_dir.name.startswith("{"):
                _copy_or_link(skill_dir, skills_dst / skill_dir.name, link, dry)
        for cmd_file in sorted((plugin_root / "commands").glob("*.md")):
            _copy_or_link(cmd_file, cmds_dst / cmd_file.name, link, dry)
        print(f"  ✅  Skills → {skills_dst}")
        print(f"  ✅  Commands → {cmds_dst}")
        _patch_codex_agents_md(dry)

    elif agent == "cursor":
        rules_dst = Path("~/.cursor/rules/squirrel").expanduser()
        for skill_dir in sorted((plugin_root / "skills").iterdir()):
            if skill_dir.is_dir() and not skill_dir.name.startswith("{"):
                _copy_or_link(skill_dir, rules_dst / skill_dir.name, link, dry)
        print(f"  ✅  Rules → {rules_dst}")

    elif agent == "copilot":
        workspace = getattr(args, "workspace", False)
        if workspace:
            import subprocess as _sp
            result = _sp.run(
                ["git", "rev-parse", "--show-toplevel"],
                capture_output=True, text=True,
            )
            if result.returncode != 0:
                import sys as _sys
                print(
                    "❌  --workspace requires a git repository, but the current "
                    "directory is not inside one.",
                    file=_sys.stderr,
                )
                _sys.exit(1)
            dest_root = Path(result.stdout.strip()) / ".github"
            print(f"  ℹ️   Workspace-level install → {dest_root}")
            print("  ℹ️   Remember to commit the generated .github/ files.")
        else:
            dest_root = Path(
                __import__("os").environ.get("COPILOT_HOME", "~/.copilot")
            ).expanduser()

        agents_dst = dest_root / "agents"
        prompts_dst = dest_root / "prompts"
        hooks_dst = dest_root / "hooks"

        if not dry:
            for d in (agents_dst, prompts_dst, hooks_dst):
                d.mkdir(parents=True, exist_ok=True)

        skills_src = plugin_root / "skills"
        if skills_src.exists():
            for skill_dir in sorted(skills_src.iterdir()):
                if skill_dir.is_dir() and not skill_dir.name.startswith("{"):
                    _copy_skill_for_copilot(skill_dir, agents_dst, link, dry)
        elif dry:
            print("  [skills] (source dir not found — run from canonical install)")

        cmds_src = plugin_root / "commands"
        if cmds_src.exists():
            for cmd_file in sorted(cmds_src.glob("*.md")):
                _copy_prompt_for_copilot(cmd_file, prompts_dst, link, dry)
        elif dry:
            print("  [commands] (source dir not found — run from canonical install)")

        print(f"  ✅  Agents → {agents_dst}")
        print(f"  ✅  Prompts → {prompts_dst}")

        _patch_copilot_instructions_md(dest_root / "copilot-instructions.md", dry)

        adapter_dir = Path("~/.claude/plugins/squirrel/companions/copilot").expanduser()
        _emit_copilot_hooks_json(hooks_dst / "squirrel.json", adapter_dir, dry)

    # standalone: no agent files — config dir only
    cfg_dir = Path("~/.squirrel").expanduser()
    if dry:
        print(f"  [mkdir] {cfg_dir}")
    else:
        cfg_dir.mkdir(parents=True, exist_ok=True)

    cfg = cfg_dir / "config.toml"
    print()
    if not cfg.exists() and not dry:
        print("  ℹ️   No config found. Run /cb-init (Claude Code) to configure.")
    elif dry:
        print(f"  [check] config → {cfg}")
    else:
        print(f"  ✅  Config → {cfg}")

    print("\n🎉  Done!")
    hints = {
        "claude": "Restart Claude Code, then /sq-where-am-i",
        "codex": "Run: codex, then /sq-where-am-i",
        "cursor": "Update Settings → Rules for AI to include squirrel",
        "copilot": "Restart VS Code / Copilot, then /sq-where-am-i",
        "standalone": "Run: cb status --help",
    }
    print(f"     Next: {hints.get(agent, '')}")


