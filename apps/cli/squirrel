def cmd_recover(args):
    from session_scanner import scan_sessions, _load_config
    vault = _vault(getattr(args, "vault", None))
    config = _load_config()
    sessions = scan_sessions(vault, args.max_age, config)
    if args.json:
        print(json.dumps(sessions, indent=2, default=str))
        return

    if not sessions:
        print("✅  No recoverable sessions.")
        return

    print(f"🔄  {len(sessions)} recoverable session(s)\n")
    for s in sessions:
        proj = s.get("project", s.get("cwd", "?"))
        agent = s.get("agent", "?")
        last = (s.get("last_seen") or s.get("started_at", ""))[:16]
        print(f"  {proj} [{agent}] — last seen {last}")
        summary = s.get("summary") or s.get("last_message", "")
        if summary:
            print(f"    {str(summary)[:80].replace(chr(10), ' ')}")


