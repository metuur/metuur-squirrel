def cmd_chunk(args):
    from chunk_helper import chunk_task
    mins = args.minutes if args.minutes else int(args.hours * 60)
    # CLI always chunks: threshold only applies to the skill's auto-suggest logic
    data = chunk_task(mins, threshold_minutes=0)
    if args.json:
        print(json.dumps(data, indent=2))
        return

    print(f"📦 {data['total_human']} → {data['total_chunks']} chunks, {len(data['sessions'])} session(s)\n")
    for phase in data["phases"]:
        bar = "█" * max(1, phase["percent"] // 5)
        print(f"  {phase['emoji']} {phase['name']:<14} {phase['total_minutes']:>3} min  {bar} {phase['percent']}%  ({phase['n_chunks']} chunk(s))")

    if len(data["sessions"]) > 1:
        print(f"\n  📅 Estimated: {data['estimated_days']} day(s) at 2 sessions/day")


