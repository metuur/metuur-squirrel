{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-outer-size",
    "core:window:allow-hide",
    "opener:default",
    "notification:default",
    "store:default",
    "autostart:default",
    "deep-link:default"
  ]
}
